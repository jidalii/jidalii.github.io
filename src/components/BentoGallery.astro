---
import { Image } from 'astro:assets';
import { getPhoto } from '../utils/photo-assets';

const { photos: photoData } = Astro.props;
const series = photoData[0]?.data?.series || [];
const items = series.map(s => ({ image: s.cover, title: s.title })).slice(0, 6);
const total = 12;
const NUM_COLS = 4, NUM_ROWS = 3;
const ctaCell = { type: 'cta' as const };
// CTA is explicitly placed at col 4, row 3 (0-indexed: col 3, row 2)
const CTA_COL = 3, CTA_ROW = 2;

// Build flat array: 11 auto-placed cells + CTA at end
// Auto-flow fills: row0[0..3], row1[4..7], row2[8..10]; CTA at row2,col3
const autoCells = [
  ...items.map(p => ({ type: 'photo' as const, image: p.image, title: p.title, alt: p.alt || p.title || '' })),
  ...Array(total - 1 - items.length).fill({ type: 'empty' as const }),
];

// Shuffle then fix coverage (keep shuffling until every row & col has ≥1 non-empty)
function gridIndex(i: number): [number, number] {
  return [Math.floor(i / NUM_COLS), i % NUM_COLS];
}
function hasCoverage(cells: typeof autoCells): boolean {
  const rows = Array(NUM_ROWS).fill(false);
  const cols = Array(NUM_COLS).fill(false);
  for (let i = 0; i < cells.length; i++) {
    if (cells[i].type !== 'empty') {
      const [r, c] = gridIndex(i);
      rows[r] = true;
      cols[c] = true;
    }
  }
  // CTA covers its position
  rows[CTA_ROW] = true;
  cols[CTA_COL] = true;
  return rows.every(Boolean) && cols.every(Boolean);
}
function shuffle(arr: typeof autoCells) {
  for (let i = arr.length - 1; i > 0; i--) {
    const j = Math.floor(Math.random() * (i + 1));
    [arr[i], arr[j]] = [arr[j], arr[i]];
  }
}
// Shuffle until coverage is met (practically always within a few attempts)
let attempts = 0;
do {
  shuffle(autoCells);
  attempts++;
} while (!hasCoverage(autoCells) && attempts < 200);

const cells = [...autoCells, ctaCell];
---

<div class="section-band band-warm">
  <div class="section reveal" style="padding-bottom:48px">
    <p class="section-label">Gallery</p>
    <h2 class="section-heading">Photos</h2>
  </div>
</div>
<div class="bento-gallery" style="background:var(--color-band-warm) var(--grain-texture);background-size:256px 256px;background-blend-mode:soft-light">
  {cells.map(cell => {
    if (cell.type === 'cta') return (
      <div class="bento-gallery-item gallery-cta">
        <a href="/photos" class="gallery-cta-link">
          <span class="gallery-cta-label">Moments captured on Nikon Z 6₂</span>
          <span class="gallery-cta-btn">View full gallery →</span>
        </a>
      </div>
    );
    if (cell.type === 'empty') return <div class="bento-gallery-item"></div>;
    return (
      <div class="bento-gallery-item photo-item">
        <Image
          src={getPhoto(cell.image)}
          alt={cell.alt}
          width={400}
          densities={[1, 2]}
          format="webp"
          quality={100}
          loading="lazy"
          decoding="async"
        />
        {cell.title && <span class="bento-gallery-caption">{cell.title}</span>}
      </div>
    );
  })}
</div>

<style>
  .bento-gallery{
    display:grid;grid-template-columns:repeat(4,1fr);
    grid-template-rows:repeat(3,1fr);
    width:100vw;max-width:1400px;margin:0 auto;
    gap:8px;padding:0 8px;
    aspect-ratio:4/3;
  }
  .bento-gallery-item{
    position:relative;overflow:hidden;background:transparent;border-radius:12px;
    aspect-ratio:1/1;transition:background 2.4s cubic-bezier(0.16,1,0.3,1);
  }
  .gallery-cta{grid-column:4;grid-row:3;background:#9BAFAC}
  .bento-gallery-item:not(.gallery-cta):hover{background:#d3ded2}
  .photo-item:hover{background:transparent}
  .bento-gallery-item :global(img){
    width:100%;height:100%;object-fit:cover;
    transition:transform .6s var(--ease-out-expo);
  }
  .photo-item:hover > :global(img){transform:scale(1.04)}

  /* ── Caption (no blur — bottom scrim keeps it readable) ── */
  .bento-gallery-caption{
    position:absolute;bottom:0;left:0;right:0;padding:30px 20px 16px;
    color:#fff;font-size:.78rem;font-weight:500;
    text-shadow:0 1px 3px rgba(0,0,0,.4);
    background:linear-gradient(to top,rgba(0,0,0,.38),transparent);
    opacity:0;transform:translateY(8px);
    transition:opacity .3s var(--ease-out-expo),transform .3s var(--ease-out-expo);
  }
  .photo-item:hover .bento-gallery-caption{opacity:1;transform:translateY(0)}
  .gallery-cta{display:flex;align-items:center;justify-content:center}
  .gallery-cta-link{display:flex;flex-direction:column;align-items:center;gap:10px;text-decoration:none}
  .gallery-cta-label{color:#F0EDE7;font-size:.82rem;font-weight:450}
  .gallery-cta-btn{
    display:inline-flex;align-items:center;gap:6px;padding:10px 22px;border-radius:12px;
    background:#EFEFEA;color:#2A3A37;font-size:.8rem;font-weight:500;
    transition:transform .2s,background .2s;
  }
  .gallery-cta-link:hover .gallery-cta-btn{background:#FFF;transform:translateY(-1px)}
  @media(max-width:768px){
    .bento-gallery{grid-template-columns:repeat(2,1fr);grid-template-rows:auto;aspect-ratio:auto}
    .gallery-cta{grid-column:2;grid-row:auto}
  }
</style>
