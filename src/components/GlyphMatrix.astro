---
const {
  colorStart = '#C4A04A',
  colorEnd = '#F0EDE7',
  reverse = false,
  glyphs = '01{}[]()/\\<>*+-=',
  cellSize = 14,
  mutationRate = 0.03,
  interval = 100,
  fadeBottom = 0.3
} = Astro.props;
const id = 'gm-' + Math.random().toString(36).slice(2, 8);
---

<div class="gm-container" style="position:relative;width:100%;height:100%;overflow:hidden">
  <canvas
    id={id}
    data-color-start={colorStart}
    data-color-end={colorEnd}
    data-glyphs={glyphs}
    data-cell-size={cellSize}
    data-mutation-rate={mutationRate}
    data-interval={interval}
    data-fade-bottom={fadeBottom}
    data-reverse={String(reverse)}
    style="position:absolute;inset:0;width:100%;height:100%;display:block"
    aria-hidden="true"
  ></canvas>
</div>

<script define:vars={{ id }}>
  (function() {
    var canvas = document.getElementById(id);
    if (!canvas) return;
    var ctx = canvas.getContext('2d');
    if (!ctx) return;

    var glyphs = canvas.dataset.glyphs.replace(/[\n\t\r]/g, '') || '01<>=-+*';
    var cellSize = parseInt(canvas.dataset.cellSize) || 14;
    var mutationRate = parseFloat(canvas.dataset.mutationRate) || 0.03;
    var interval = parseInt(canvas.dataset.interval) || 100;
    var fadeBottom = parseFloat(canvas.dataset.fadeBottom) ?? 0.3;
    var reverse = canvas.dataset.reverse === 'true';
    var colorStart = canvas.dataset.colorStart || '#C4A04A';
    var colorEnd = canvas.dataset.colorEnd || '#F0EDE7';

    var cols = 0, rows = 0, cells = [], alphas = [];
    var rafId = 0, lastTime = 0, stopped = false;
    var cw = 0, ch = 0;

    function getRgba(c) {
      var probe = document.createElement('canvas');
      probe.width = 1; probe.height = 1;
      var pctx = probe.getContext('2d');
      pctx.fillStyle = c;
      pctx.fillRect(0, 0, 1, 1);
      var px = pctx.getImageData(0, 0, 1, 1).data;
      return { r: px[0], g: px[1], b: px[2], a: px[3] / 255 };
    }

    var c1 = getRgba(colorStart);
    var c2 = getRgba(colorEnd);

    function resize(w, h) {
      var dpr = window.devicePixelRatio || 1;
      canvas.width = w * dpr;
      canvas.height = h * dpr;
      ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
      cw = w; ch = h;
      cols = Math.ceil(w / cellSize);
      rows = Math.ceil(h / cellSize);
      var total = cols * rows;
      cells = new Array(total);
      alphas = new Array(total);
      for (var i = 0; i < total; i++) {
        cells[i] = glyphs[Math.floor(Math.random() * glyphs.length)];
        alphas[i] = 0.18 + Math.random() * 0.57;
      }
    }

    function draw() {
      if (stopped || cw === 0 || ch === 0) return;
      ctx.clearRect(0, 0, cw, ch);

      // Read CSS band colors each frame with light-theme fallbacks
      var styles = getComputedStyle(document.documentElement);
      var warmBg = styles.getPropertyValue('--color-band-warm').trim() || '#f4f0ea';
      var coolBg = styles.getPropertyValue('--color-band-cool').trim() || '#d3ded2';

      var bgGrad = ctx.createLinearGradient(0, 0, 0, ch);
      bgGrad.addColorStop(0, reverse ? coolBg : warmBg);
      bgGrad.addColorStop(1, reverse ? warmBg : coolBg);
      ctx.fillStyle = bgGrad;
      ctx.fillRect(0, 0, cw, ch);

      ctx.font = (cellSize - 2) + 'px ui-monospace, SFMono-Regular, Menlo, Monaco, monospace';
      ctx.textBaseline = 'top';

      for (var y = 0; y < rows; y++) {
        var yRatio = rows > 1 ? y / (rows - 1) : 0;
        var fade = fadeBottom > 0 ? 1 - yRatio * fadeBottom : 1;
        var tr = Math.round(c1.r + (c2.r - c1.r) * yRatio);
        var tg = Math.round(c1.g + (c2.g - c1.g) * yRatio);
        var tb = Math.round(c1.b + (c2.b - c1.b) * yRatio);

        ctx.fillStyle = 'rgba(' + tr + ',' + tg + ',' + tb + ',' + fade + ')';

        for (var x = 0; x < cols; x++) {
          var i = y * cols + x;
          if (i >= cells.length) continue;
          ctx.fillText(cells[i], x * cellSize, y * cellSize);
        }
      }
    }

    function tick(t) {
      if (stopped) return;
      if (t - lastTime >= interval) {
        lastTime = t;
        var total = cols * rows;
        if (total > 0) {
          var mutations = Math.max(1, Math.floor(total * mutationRate));
          for (var n = 0; n < mutations; n++) {
            var i = Math.floor(Math.random() * total);
            if (i < cells.length) {
              cells[i] = glyphs[Math.floor(Math.random() * glyphs.length)];
              alphas[i] = 0.18 + Math.random() * 0.57;
            }
          }
          draw();
        }
      }
      rafId = requestAnimationFrame(tick);
    }

    var parent = canvas.parentElement;
    var ro = new ResizeObserver(function(entries) {
      for (var e = 0; e < entries.length; e++) {
        var w = entries[e].contentRect.width;
        var h = entries[e].contentRect.height;
        if (w > 0 && h > 0) { resize(w, h); draw(); }
      }
    });
    ro.observe(parent || canvas);
    rafId = requestAnimationFrame(tick);
  })();
</script>
