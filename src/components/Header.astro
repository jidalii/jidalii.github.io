---
const currentPath = Astro.url?.pathname || '/';

const links = [
  { href: '/blog/1', label: 'Blog' },
  { href: '/photos', label: 'Photos' },
  { href: '/about', label: 'About' },
  { href: '/CV_Jida_Li.pdf', label: 'Résumé', external: true },
];

function isActive(path: string) {
  if (path === '/' && currentPath === '/') return true;
  if (path !== '/' && currentPath.startsWith(path)) return true;
  return false;
}
---

<header id="site-header">
  <nav class="nav-bar" id="nav-bar">
    <div class="nav-inner">
      <a href="/" class="nav-logo">Jida Li</a>

      <!-- Desktop nav -->
      <ul class="nav-links" id="nav-links">
        {links.map(link => (
          <li>
            <a
              href={link.href}
              class={`nav-link${isActive(link.href) ? ' active' : ''}`}
              data-flip-link
              {...(link.external ? { target: '_blank', rel: 'noopener' } : {})}
            >
              {link.label}
              {link.external && <span class="nav-arrow" aria-hidden="true">↗</span>}
            </a>
          </li>
        ))}
      </ul>

      <!-- Mobile toggle -->
      <button
        class="nav-menu-btn"
        id="nav-menu-btn"
        aria-label="Toggle menu"
        aria-expanded="false"
      >
        <span class="nav-menu-line"></span>
        <span class="nav-menu-line"></span>
      </button>
    </div>

    <!-- Mobile menu -->
    <div class="nav-mobile" id="nav-mobile">
      <ul class="nav-mobile-links">
        {links.map(link => (
          <li>
            <a
              href={link.href}
              class={`nav-mobile-link${isActive(link.href) ? ' active' : ''}`}
              {...(link.external ? { target: '_blank', rel: 'noopener' } : {})}
            >
              {link.label}
              {link.external && <span class="nav-arrow" aria-hidden="true">↗</span>}
            </a>
          </li>
        ))}
      </ul>
    </div>
  </nav>
</header>

<style is:global>
  /* ═══ NAV BAR ═══ */
  #site-header { --nav-h: 60px; height: var(--nav-h); }

  .nav-bar {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 100;
    height: var(--nav-h);
    border-bottom: 1px solid transparent;
    transition: background 0.35s, border-color 0.35s, box-shadow 0.35s;
  }
  .nav-bar.scrolled {
    background: color-mix(in srgb, var(--color-bg) 90%, transparent);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border-bottom-color: var(--color-border);
    box-shadow: 0 1px 0 0 rgba(0,0,0,0.04);
  }

  .nav-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: var(--nav-h);
    max-width: var(--max-content);
    margin: 0 auto;
    padding: 0 28px;
    position: relative;
  }

  .nav-logo {
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: 500;
    color: var(--color-text-primary);
    text-decoration: none;
    letter-spacing: 0.03em;
    position: relative;
    z-index: 2;
  }

  /* ── Desktop links ── */
  .nav-links {
    display: none;
    list-style: none;
    gap: 36px;
    align-items: center;
    margin: 0; padding: 0;
  }
  @media (min-width: 640px) { .nav-links { display: flex; } }

  .nav-link {
    font-size: 0.875rem;
    font-weight: 400;
    color: var(--color-text-secondary);
    text-decoration: none;
    letter-spacing: 0.03em;
    transition: color 0.2s;
    position: relative;
    padding: 4px 0;
  }
  .nav-link:hover { color: var(--color-text-primary); }
  .nav-link.active { color: var(--color-text-primary); }

  .nav-arrow {
    display: inline-block;
    font-size: 0.7rem;
    margin-left: 2px;
    vertical-align: super;
    color: var(--color-text-tertiary);
    transition: color 0.2s;
  }
  .nav-link:hover .nav-arrow { color: var(--color-text-primary); }

  /* ── Mobile menu button ── */
  .nav-menu-btn {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 28px;
    height: 28px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0;
    position: relative;
    z-index: 2;
  }
  @media (min-width: 640px) { .nav-menu-btn { display: none; } }

  .nav-menu-line {
    display: block;
    width: 20px;
    height: 1.5px;
    background: var(--color-text-primary);
    border-radius: 1px;
    transition: transform 0.35s cubic-bezier(0.22, 1, 0.36, 1),
                opacity 0.2s;
    transform-origin: center;
    margin: 0 auto;
  }
  .nav-menu-btn.open .nav-menu-line:first-child {
    transform: translateY(3.25px) rotate(45deg);
  }
  .nav-menu-btn.open .nav-menu-line:last-child {
    transform: translateY(-3.25px) rotate(-45deg);
  }

  /* ── Mobile menu panel ── */
  .nav-mobile {
    position: fixed;
    top: var(--nav-h);
    left: 0; right: 0;
    background: color-mix(in srgb, var(--color-bg) 95%, transparent);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border-bottom: 1px solid var(--color-border);
    overflow: hidden;
    max-height: 0;
    opacity: 0;
    transition: max-height 0.4s cubic-bezier(0.22, 1, 0.36, 1),
                opacity 0.3s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .nav-mobile.open {
    max-height: 320px;
    opacity: 1;
  }

  .nav-mobile-links {
    list-style: none;
    padding: 16px 28px 24px;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .nav-mobile-link {
    display: block;
    font-size: 1rem;
    font-weight: 400;
    color: var(--color-text-secondary);
    text-decoration: none;
    padding: 10px 0;
    letter-spacing: 0.03em;
    transition: color 0.2s;
  }
  .nav-mobile-link:hover,
  .nav-mobile-link.active { color: var(--color-text-primary); }

  /* ── 3D Flip Link ── */
  [data-flip-link] {
    perspective: 200px;
    display: inline-block;
  }
  .flip-word { display: inline-flex; white-space: pre; }
  .flip-char { display: inline-block; white-space: pre; }
  .flip-char-inner {
    display: inline-block;
    position: relative;
    transform-style: preserve-3d;
    transition: transform 0.42s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .flip-front, .flip-back {
    display: inline-block;
    backface-visibility: hidden;
  }
  .flip-back {
    position: absolute;
    top: 0; left: 0;
    transform: rotateY(180deg);
  }
</style>

<script>
  // ═══ Scroll-based blur ═══
  (function scrollBlur() {
    var bar = document.getElementById('nav-bar');
    if (!bar) return;
    function update() {
      if (window.scrollY > 10) bar.classList.add('scrolled');
      else bar.classList.remove('scrolled');
    }
    update();
    var ticking = false;
    window.addEventListener('scroll', function() {
      if (!ticking) { requestAnimationFrame(function() { update(); ticking = false; }); ticking = true; }
    }, { passive: true });
  })();

  // ═══ Mobile menu toggle ═══
  (function mobileMenu() {
    var btn = document.getElementById('nav-menu-btn');
    var panel = document.getElementById('nav-mobile');
    if (!btn || !panel) return;
    function close() {
      btn.classList.remove('open');
      btn.setAttribute('aria-expanded', 'false');
      panel.classList.remove('open');
    }
    btn.addEventListener('click', function() {
      if (btn.classList.contains('open')) close();
      else {
        btn.classList.add('open');
        btn.setAttribute('aria-expanded', 'true');
        panel.classList.add('open');
      }
    });
    panel.querySelectorAll('a').forEach(function(a) { a.addEventListener('click', close); });
    document.addEventListener('click', function(e) {
      if (panel.classList.contains('open') && !panel.contains(e.target) && e.target !== btn && !btn.contains(e.target)) close();
    });
  })();

  // ═══ 3D Flip effect ═══
  (function flipInit() {
    var HAS_SEGMENTER = typeof Intl !== 'undefined' && 'Segmenter' in Intl;
    function splitIntoCharacters(text) {
      if (HAS_SEGMENTER) {
        var s = new Intl.Segmenter('en', { granularity: 'grapheme' });
        return Array.from(s.segment(text), function(x) { return x.segment; });
      }
      return Array.from(text);
    }
    function wrapLink(link) {
      var text = link.textContent?.replace(/↗/, '').trim() || '';
      link.setAttribute('data-original-text', text);
      var chars = splitIntoCharacters(text);
      while (link.firstChild) link.removeChild(link.firstChild);
      var word = document.createElement('span');
      word.className = 'flip-word';
      chars.forEach(function(char) {
        var cw = document.createElement('span'); cw.className = 'flip-char';
        var inner = document.createElement('span'); inner.className = 'flip-char-inner';
        var front = document.createElement('span'); front.className = 'flip-front'; front.textContent = char;
        var back = document.createElement('span'); back.className = 'flip-back'; back.textContent = char; back.setAttribute('aria-hidden', 'true');
        inner.appendChild(front); inner.appendChild(back);
        cw.appendChild(inner); word.appendChild(cw);
      });
      link.appendChild(word);
      link.setAttribute('data-flip-wrapped', '');
      return link;
    }
    function setupFlip(link) {
      var timer = null, flipping = false;
      var totalChars = splitIntoCharacters(link.getAttribute('data-original-text') || '').length;
      var stagger = 0.07, flipDuration = 500, returnDuration = 320, returnStagger = 0.05, hold = 200;
      var totalTime = (totalChars - 1) * stagger * 1000 + flipDuration + hold + (totalChars - 1) * returnStagger * 1000 + returnDuration;
      link.addEventListener('mouseenter', function() {
        if (flipping) return; flipping = true;
        var chars = link.querySelectorAll('.flip-char');
        chars.forEach(function(c) { var i = c.querySelector('.flip-char-inner'); if (i) { i.style.transition = 'none'; i.style.transform = ''; i.style.transitionDelay = ''; } });
        link.offsetHeight;
        chars.forEach(function(c, i) { var inn = c.querySelector('.flip-char-inner'); if (inn) { inn.style.transition = 'transform ' + flipDuration + 'ms cubic-bezier(0.16, 1, 0.3, 1)'; inn.style.transitionDelay = (i * stagger) + 's'; inn.style.transform = 'rotateY(-180deg)'; } });
        clearTimeout(timer);
        var flipInEnd = (totalChars - 1) * stagger * 1000 + flipDuration + hold;
        timer = setTimeout(function() {
          chars.forEach(function(c, i) { var rev = totalChars - 1 - i; var inn = c.querySelector('.flip-char-inner'); if (inn) { inn.style.transition = 'transform ' + returnDuration + 'ms cubic-bezier(0.16, 1, 0.3, 1)'; inn.style.transitionDelay = (rev * returnStagger) + 's'; inn.style.transform = ''; } });
          timer = setTimeout(function() { chars.forEach(function(c) { var inn = c.querySelector('.flip-char-inner'); if (inn) { inn.style.transition = ''; inn.style.transitionDelay = ''; } }); flipping = false; }, (totalChars - 1) * returnStagger * 1000 + returnDuration);
        }, flipInEnd);
      });
      link.addEventListener('mouseleave', function() { clearTimeout(timer); link.querySelectorAll('.flip-char').forEach(function(c) { var inn = c.querySelector('.flip-char-inner'); if (inn) { inn.style.transition = 'transform 150ms cubic-bezier(0.16, 1, 0.3, 1)'; inn.style.transitionDelay = ''; inn.style.transform = ''; } }); flipping = false; });
    }
    function init() {
      document.querySelectorAll('[data-flip-link]:not([data-flip-wrapped])').forEach(function(link) { setupFlip(wrapLink(link)); });
    }
    if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', init); else init();
    document.addEventListener('astro:page-load', init);
  })();
</script>
