---
import BaseLayout from '../../layouts/BaseLayout.astro';
import GlyphMatrix from '../../components/GlyphMatrix.astro';
---

<BaseLayout>
  <div class="section-band band-warm" style="padding-top:140px;padding-bottom:60px">
    <section class="section">
      <p class="section-label">About</p>
      <h2 class="section-heading">Jida Li</h2>
      <div style="max-width:var(--max-reading)">
        <p class="text-lg mb-4" style="color:var(--color-text-secondary);line-height:1.7">Backend engineer specializing in blockchain infrastructure and distributed systems. Currently building MPC signing services at Presto Labs in Shanghai. Boston University CS graduate (GPA 3.93).</p>
        <p class="text-lg mb-4" style="color:var(--color-text-secondary);line-height:1.7">When I'm not writing Go, I'm behind a Nikon Z 6₂ — photography is how I practice seeing the world more carefully.</p>
        <p class="mt-6"><a href="/CV_Jida_Li.pdf" class="inline-flex items-center gap-1.5 px-6 py-3 rounded text-sm font-medium no-underline" style="background:var(--color-accent-yellow);color:var(--color-text-inverse)">Download Résumé ↓</a></p>
      </div>
    </section>
  </div>

  <div class="band-dither dither-warm-cool">
    <GlyphMatrix colorStart="#C4A04A" colorEnd="#8DA896" glyphs="01{}[]()/\\<>*+-=" cellSize={16} mutationRate={0.04} interval={80} fadeBottom={0.3} />
  </div>

  <div class="section-band band-cool" style="padding-top:60px">
    <section class="section">
      <p class="section-label">Skills</p>
      <div class="grid grid-cols-3 gap-8 md:grid-cols-1">
        <div><strong style="font-family:var(--font-display);font-size:1rem;color:var(--color-text-primary);display:block;margin-bottom:8px">Languages</strong><p class="text-sm" style="color:#3F4A47">Go, C++, Python, Solidity, Rust, SQL</p></div>
        <div><strong style="font-family:var(--font-display);font-size:1rem;color:var(--color-text-primary);display:block;margin-bottom:8px">Frameworks</strong><p class="text-sm" style="color:#3F4A47">Gin, Foundry, The Graph, go-zero, Streamlit, FastAPI</p></div>
        <div><strong style="font-family:var(--font-display);font-size:1rem;color:var(--color-text-primary);display:block;margin-bottom:8px">Infrastructure</strong><p class="text-sm" style="color:#3F4A47">Kafka, Redis, Docker, PostgreSQL, Prometheus, Grafana, Linux</p></div>
      </div>
    </section>
  </div>
</BaseLayout>

<style>
  .section-band{position:relative;padding:80px 0}
  .band-warm{background:var(--color-band-warm)}
  .band-cool{background:var(--color-band-cool)}
  .band-dither{position:relative;width:100%;height:140px;overflow:hidden;margin-top:-1px;margin-bottom:-1px;z-index:2}
  .dither-warm-cool{background-color:transparent}
</style>
