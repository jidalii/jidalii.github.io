---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollectionByName } from '../../utils/getCollectionByName';
import { site } from '../../consts';

export async function getStaticPaths({ paginate }) {
  const posts = await getCollectionByName('blog');
  const sorted = posts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
  return paginate(sorted, { pageSize: site.postPageSize });
}

const { page } = Astro.props;
---

<BaseLayout>
  <div class="section-band band-warm" style="padding-top:140px">
    <section class="section">
      <h2 class="section-heading" style="font-size:clamp(2rem,4vw,2.8rem)">Blog</h2>
      <div class="flex flex-col">
        {page.data.map(post => (
          <a href={`/blog/${post.id}`} class="grid items-baseline border-b border-[var(--color-border)] no-underline text-inherit hover:pl-2 transition-all duration-300" style="grid-template-columns:120px 1fr 80px;gap:48px;padding:48px 0">
            <span class="text-xs font-medium" style="font-family:var(--font-mono);color:var(--color-text-tertiary);padding-top:4px">{new Date(post.data.date).toISOString().slice(0,7)}</span>
            <span>
              <h4 style="font-family:var(--font-display);font-size:1.4rem;font-weight:500;color:var(--color-text-primary);line-height:1.4;margin:0 0 12px 0">{post.data.title}</h4>
              <p class="text-sm" style="color:var(--color-text-secondary);line-height:1.65;margin:0">{post.data.description || ''}</p>
            </span>
            <span class="text-right text-xs font-medium" style="font-family:var(--font-mono);color:var(--color-text-tertiary);padding-top:4px">{post.data.readingTime?.text || ''}</span>
          </a>
        ))}
      </div>
    </section>
  </div>
</BaseLayout>
