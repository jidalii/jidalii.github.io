---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const MATS = ['#e5e9e1','#acc2b2','#e9e1e1','#e5e7e3','#d0d3dc','#acc2c2','#c6cfbe','#cfbecb','#e3e4e7','#c2bcac','#b1b4bd','#c6cbc2','#c2c4cb','#e1e9e3','#b7bdb1','#d6dcd0','#d2d9d9','#acb2c2','#d0dcd3','#d6d9d2','#cfcbbe','#c6c2cb','#e1e9e9','#b7b1bd','#cfbebe','#e3e7e4','#b1bdb4','#e5e1e9','#d9d2d2','#c2acbc','#e5e3e7','#b7acc2','#cbc9c2','#bdb1b1','#d9d2d7','#d2d9d4','#d2d4d9','#c2cbc4','#d6d2d9','#d9d7d2','#becfcf','#d6d0dc','#e3e7e7','#b1bdbd','#cbc2c9','#dcd9d0','#c6becf','#e7e3e6','#cbc2c2','#becfc2','#d0dcdc','#dcd0d0','#c2cbcb','#bdb1ba','#bec2cf','#e7e3e3','#dcd0d9','#bdbab1','#e9e1e7','#e9e7e1','#b7c2ac','#e1e3e9','#c2acac','#e7e6e3'];
  const photoMat = (path: string) => { let h = 0; for (let i = 0; i < path.length; i++) { h = ((h << 5) - h) + path.charCodeAt(i); h |= 0; } return MATS[Math.abs(h) % MATS.length]; };
  const slugify = (path: string) => {
    const parts = path.split('/');
    const dir = parts.length > 2 ? parts[parts.length - 2] + '-' : '';
    return dir + (parts.pop()?.replace(/\.[^.]+$/, '') || '');
  };
  const photoData = await getCollection('photos');
  const allSeries = photoData[0]?.data?.series || [];
  const paths: any[] = [];
  for (const s of allSeries) {
    for (let i = 0; i < s.photos.length; i++) {
      const photo = s.photos[i];
      paths.push({
        params: { slug: slugify(photo) },
        props: { series: s, photoIdx: i, allSeries, bgColor: photoMat(photo) }
      });
    }
  }
  return paths;
}

const slugify = (path: string) => { const parts = path.split('/'); const dir = parts.length > 2 ? parts[parts.length - 2] + '-' : ''; return dir + (parts.pop()?.replace(/\.[^.]+$/, '') || ''); };
const { series, photoIdx, allSeries, bgColor } = Astro.props;

// Determine text color based on bg luminance
const r = parseInt(bgColor.slice(1,3),16), g = parseInt(bgColor.slice(3,5),16), b = parseInt(bgColor.slice(5,7),16);
const lum = 0.299*r + 0.587*g + 0.114*b;
const textColor = lum > 150 ? '#141311' : '#F0EDE7';
const mutedColor = lum > 150 ? '#6B665E' : '#9C968D';
const photos = series.photos;
const currentPhoto = photos[photoIdx];
const prevIdx = photoIdx > 0 ? photoIdx - 1 : photos.length - 1;
const nextIdx = photoIdx < photos.length - 1 ? photoIdx + 1 : 0;
const prevPhoto = photos[prevIdx];
const nextPhoto = photos[nextIdx];
---

<BaseLayout>
  <div style={`background:${bgColor};position:fixed;inset:0;display:flex;align-items:center;justify-content:center;padding:120px 0 40px`}>
    <div class="photo-viewer">
      <button id="prev-btn" class="photo-arrow photo-arrow-left" aria-label="Previous" data-url={`/photos/${slugify(prevPhoto)}`} style={`color:${mutedColor};background:none;border:none;cursor:pointer`}>
        <span>←</span>
      </button>

      <div class="photo-main">
        <img id="main-photo" src={currentPhoto} alt={series.title} />
        <div class="photo-info">
          <span id="photo-title" class="photo-title" style={`color:${textColor}`}>{series.title}</span>
          <span id="photo-counter" class="photo-counter" style={`color:${mutedColor}`}>{photoIdx + 1} / {photos.length}</span>
        </div>
      </div>

      <button id="next-btn" class="photo-arrow photo-arrow-right" aria-label="Next" data-url={`/photos/${slugify(nextPhoto)}`} style={`color:${mutedColor};background:none;border:none;cursor:pointer`}>
        <span>→</span>
      </button>
    </div>
  </div>
</BaseLayout>

<script>
  // Hide footer on photo detail pages
  var footer = document.querySelector('footer');
  if (footer) footer.style.display = 'none';
</script>

<script>
  function navigate(url) {
    var img = document.getElementById('main-photo');
    img.style.opacity = '0';
    fetch(url).then(function(r){ return r.text() }).then(function(html) {
      var parser = new DOMParser();
      var doc = parser.parseFromString(html, 'text/html');
      // Swap image
      var newImg = doc.getElementById('main-photo');
      if (newImg) { img.src = newImg.src; img.alt = newImg.alt; }
      // Swap title and counter
      var newTitle = doc.getElementById('photo-title');
      var newCounter = doc.getElementById('photo-counter');
      if (newTitle) document.getElementById('photo-title').textContent = newTitle.textContent;
      if (newCounter) document.getElementById('photo-counter').textContent = newCounter.textContent;
      // Update button URLs from fetched page
      var newPrev = doc.getElementById('prev-btn');
      var newNext = doc.getElementById('next-btn');
      if (newPrev) document.getElementById('prev-btn').dataset.url = newPrev.dataset.url;
      if (newNext) document.getElementById('next-btn').dataset.url = newNext.dataset.url;
      // Update URL
      history.replaceState(null, '', url);
      // Update background color from fetched page
      var newBg = doc.querySelector('[style*="background"]');
      // Fade back
      img.onload = function() { img.style.opacity = '1'; };
      setTimeout(function() { img.style.opacity = '1'; }, 50);
    });
  }
  document.getElementById('prev-btn').onclick = function() { navigate(this.dataset.url); };
  document.getElementById('next-btn').onclick = function() { navigate(this.dataset.url); };
  document.addEventListener('keydown', function(e) {
    if (e.key === 'ArrowLeft') document.getElementById('prev-btn').click();
    if (e.key === 'ArrowRight') document.getElementById('next-btn').click();
  });
</script>

<script define:vars={{ bgColor }}>
  document.documentElement.style.setProperty('--color-bg', bgColor);
  document.documentElement.style.setProperty('--color-band-warm', bgColor);
  var nav = document.querySelector('nav');
  if (nav) {
    nav.style.background = 'transparent';
    nav.style.backdropFilter = 'none';
    nav.style.webkitBackdropFilter = 'none';
    nav.style.borderBottom = 'none';
  }
</script>

<style>
  .photo-viewer { display: flex; align-items: center; justify-content: center; width: 100%; min-height: 100vh; padding: 80px 0; }
  .photo-main { display: flex; flex-direction: column; align-items: center; max-width: 90vw; max-height: 85vh; }
  .photo-main img { max-width: 90vw; max-height: 75vh; object-fit: contain; border-radius: 4px; }
  .photo-info { display: flex; align-items: center; gap: 16px; margin-top: 20px; }
  .photo-title { font-family: var(--font-display); font-size: 1.1rem; color: var(--color-text-primary); }
  .photo-counter { font-family: var(--font-mono); font-size: .75rem; color: var(--color-text-tertiary); }
  .photo-arrow { position: fixed; top: 50%; transform: translateY(-50%); display: flex; align-items: center; justify-content: center; width: 64px; height: 64px; border-radius: 50%; text-decoration: none; font-size: 1.5rem; transition: color .2s, background .2s; flex-shrink: 0; z-index: 10; }
  .photo-arrow:hover { color: var(--color-accent-yellow) !important; background: color-mix(in srgb, var(--color-accent-yellow) 8%, transparent); }
  .photo-arrow-left { left: 16px; }
  .photo-arrow-right { right: 16px; }
  @media(max-width:768px){ .photo-arrow { width: 48px; height: 48px; font-size: 1.2rem; } .photo-arrow-left { left: 8px; } .photo-arrow-right { right: 8px; } .photo-main img { max-width: 85vw; max-height: 65vh; } }
</style>
