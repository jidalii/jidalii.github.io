---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const photoData = await getCollection('photos');
const allSeries = photoData[0]?.data?.series || [];

// ── 64-color Morandi mat palette ──
const MATS = ['#e5e9e1','#acc2b2','#e9e1e1','#e5e7e3','#d0d3dc','#acc2c2','#c6cfbe','#cfbecb','#e3e4e7','#c2bcac','#b1b4bd','#c6cbc2','#c2c4cb','#e1e9e3','#b7bdb1','#d6dcd0','#d2d9d9','#acb2c2','#d0dcd3','#d6d9d2','#cfcbbe','#c6c2cb','#e1e9e9','#b7b1bd','#cfbebe','#e3e7e4','#b1bdb4','#e5e1e9','#d9d2d2','#c2acbc','#e5e3e7','#b7acc2','#cbc9c2','#bdb1b1','#d9d2d7','#d2d9d4','#d2d4d9','#c2cbc4','#d6d2d9','#d9d7d2','#becfcf','#d6d0dc','#e3e7e7','#b1bdbd','#cbc2c9','#dcd9d0','#c6becf','#e7e3e6','#cbc2c2','#becfc2','#d0dcdc','#dcd0d0','#c2cbcb','#bdb1ba','#bec2cf','#e7e3e3','#dcd0d9','#bdbab1','#e9e1e7','#e9e7e1','#b7c2ac','#e1e3e9','#c2acac','#e7e6e3'];
const WARM: string[] = [], COOL: string[] = [];
for (const m of MATS) {
  const r = parseInt(m.slice(1,3),16), g = parseInt(m.slice(3,5),16), b = parseInt(m.slice(5,7),16);
  if (r > b + 10) WARM.push(m);
  else if (b > r + 5) COOL.push(m);
  else { WARM.push(m); COOL.push(m); }
}
function hashStr(s: string): number { let h = 0; for (let i = 0; i < s.length; i++) { h = ((h << 5) - h) + s.charCodeAt(i); h |= 0; } return Math.abs(h); }
let lastColor = '';
function pickMat(cover: string): string {
  const photoIsWarm = hashStr(cover) % 2 === 0;
  const pool = photoIsWarm ? COOL : WARM;
  let color = pool[0];
  for (let attempt = 0; attempt < pool.length; attempt++) {
    const c = pool[Math.floor(Math.random() * pool.length)];
    if (c !== lastColor) { color = c; break; }
  }
  lastColor = color;
  return color;
}

// Sort: landscapes (coverW > coverH) → single rows, portraits → pair rows
const landscapes = allSeries.filter(s => (s.coverW && s.coverH) ? s.coverW > s.coverH : true);
const portraits = allSeries.filter(s => s.coverW && s.coverH && s.coverW <= s.coverH);

interface Row { type: 'single' | 'pair'; series: typeof allSeries; colors: string[]; }
const rows: Row[] = [];
let li = 0, pi = 0;
while (li < landscapes.length || pi < portraits.length) {
  if (li < landscapes.length) {
    const s = landscapes[li++];
    rows.push({ type: 'single', series: [s], colors: [pickMat(s.cover)] });
  }
  const a = portraits[pi++], b = portraits[pi++];
  if (a && b) {
    rows.push({ type: 'pair', series: [a, b], colors: [pickMat(a.cover), pickMat(b.cover)] });
  } else if (a) {
    rows.push({ type: 'single', series: [a], colors: [pickMat(a.cover)] });
  }
}

function slugify(path: string) { const parts = path.split('/'); const dir = parts.length > 2 ? parts[parts.length - 2] + '-' : ''; return dir + (parts.pop()?.replace(/\.[^.]+$/, '') || ''); }
---

<BaseLayout>
  <div class="section-band band-warm" style="padding-top:140px">
    <section style="max-width:100%;padding:0">
      <div class="page-header">
        <p class="section-label">Gallery</p>
        <h2 class="section-heading">Photos</h2>
        <p style="color:var(--color-text-secondary);max-width:540px;margin-bottom:48px">A selection of moments captured on Nikon Z 6₂. Landscapes, streets, portraits.</p>
      </div>

      {rows.map(row => (
        <div
          class={`photo-row ${row.type}`}
          style={row.type === 'pair'
            ? `background:linear-gradient(to right, ${row.colors[0]} 0%, ${row.colors[0]} 50%, ${row.colors[1]} 50%, ${row.colors[1]} 100%)`
            : `background:${row.colors[0]}`}
        >
          {row.series.map(s => (
            <a class="photo-inner" href={`/photos/${slugify(s.cover)}`} style="text-decoration:none">
              <img src={s.cover} alt={s.title} loading="lazy" />
              <span class="photo-caption">{s.title}</span>
            </a>
          ))}
        </div>
      ))}

    </section>
  </div>
</BaseLayout>

<style>
  .page-header { max-width: var(--max-content); margin: 0 auto 56px; padding: 0 28px; }
  .photo-row { width: 100%; padding: 60px 28px; display: flex; justify-content: center; align-items: center; }
  .photo-row img { display: block; border-radius: 4px; transition: transform .4s var(--ease-out-expo); object-fit: contain; }
  .photo-row:hover img { transform: scale(1.01); }
  .photo-inner { text-decoration: none; color: inherit; }
  .photo-row.single .photo-inner { max-width: 980px; width: 100%; display: flex; flex-direction: column; align-items: center; justify-content: center; min-height: 50vh; }
  .photo-row.single img { width: 100%; height: auto; max-height: 65vh; }
  .photo-row.pair .photo-inner { width: 50%; max-width: 480px; display: flex; flex-direction: column; align-items: center; justify-content: center; min-height: 40vh; margin: 0 auto; }
  .photo-row.pair img { width: 100%; height: auto; max-height: 55vh; }
  .photo-caption { margin-top: 14px; font-family: var(--font-mono); font-size: .7rem; color: var(--color-text-secondary); letter-spacing: .04em; opacity: .6; text-align: center; }
  @media(max-width:768px){ .photo-row { padding: 32px 16px; } .photo-row.pair { flex-direction: column; gap: 24px; } .photo-row.pair .photo-inner { width: 100%; max-width: 100%; } .photo-row.single .photo-inner { min-height: 30vh; } .photo-row.pair .photo-inner { min-height: 25vh; } }
</style>
